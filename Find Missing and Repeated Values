class Solution {
    public int[] findMissingAndRepeatedValues(int[][] grid) {
        int n = grid.length;
        int totalElements = n * n;
        
        int[] counts = new int[totalElements + 1];

        // Fixed: Changed i <= n to i < n
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                int num = grid[i][j];
                counts[num]++;
            }
        }

        int repeated = -1;
        int missing = -1;

        for (int i = 1; i <= totalElements; i++) {
            if (counts[i] == 2) {
                repeated = i;
            } else if (counts[i] == 0) {
                missing = i;
            }
        }

        return new int[] {repeated, missing};
    }
}
