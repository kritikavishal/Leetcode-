


class Solution {
    // A helper class to bind start time, end time, and original position together
    static class Meeting {
        int start;
        int end;
        int id;

        Meeting(int start, int end, int id) {
            this.start = start;
            this.end = end;
            this.id = id;
        }
    }

    public ArrayList<Integer> maxMeetings(int[] s, int[] f) {
        ArrayList<Integer> res = new ArrayList<>();
        int n = s.length;
        ArrayList<Meeting> meetings = new ArrayList<>();

        // 1. Create meeting objects with 1-based indexing (standard for this problem)
        for (int i = 0; i < n; i++) {
            meetings.add(new Meeting(s[i], f[i], i + 1));
        }

        // 2. Sort meetings based on their finishing times
        // If finish times are identical, sort by their original appearance/id
        Collections.sort(meetings, new Comparator<Meeting>() {
            @Override
            public int compare(Meeting m1, Meeting m2) {
                if (m1.end != m2.end) {
                    return Integer.compare(m1.end, m2.end);
                }
                return Integer.compare(m1.id, m2.id);
            }
        });

        // 3. Greedily select meetings
        if (!meetings.isEmpty()) {
            // The first meeting in the sorted list always finishes first, so we take it
            Meeting firstMeeting = meetings.get(0);
            res.add(firstMeeting.id);
            int lastFinishTime = firstMeeting.end;

            // Check the rest of the meetings
            for (int i = 1; i < n; i++) {
                Meeting current = meetings.get(i);
                if (current.start > lastFinishTime) {
                    res.add(current.id);
                    lastFinishTime = current.end; // Update the timeline
                }
            }
        }

        // Optional: Sort result if the problem requires indices in increasing order
        // Collections.sort(res); 

        return res;
    }
}
