class TreeNode:
    def __init__(self, val=0, left=None, right=None):
        self.val = val
        self.left = left
        self.right = right

class Solution:
    def maxPathSum(self, root: TreeNode) -> int:
        # Initialize our global max to negative infinity
        self.max_sum = float('-inf')
        
        def max_gain(node):
            if not node:
                return 0
            
            # Recursively get the max gain from left and right subtrees.
            # We use max(gain, 0) because we should ignore paths with negative sums.
            left_gain = max(max_gain(node.left), 0)
            right_gain = max(max_gain(node.right), 0)
            
            # Calculate the price of the "arch" path through the current node
            current_arch_sum = node.val + left_gain + right_gain
            
            # Update the global maximum if this arch is the best we've seen
            self.max_sum = max(self.max_sum, current_arch_sum)
            
            # Return the maximum gain this node can contribute to its parent
            # It can only include one of its subtrees (left or right)
            return node.val + max(left_gain, right_gain)
        
        # Start the recursion from the root
        max_gain(root)
        
        return self.max_sum
