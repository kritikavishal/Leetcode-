import java.util.Arrays;
import java.util.Comparator;

class Solution {
    // 1. Create a helper class to bind the value, weight, and ratio together
    static class Item {
        int val;
        int wt;
        double ratio;
        
        public Item(int val, int wt) {
            this.val = val;
            this.wt = wt;
            // Cast to double to prevent integer division (e.g., 5/2 becoming 2 instead of 2.5)
            this.ratio = (double) val / wt; 
        }
    }

    public double fractionalKnapsack(int[] val, int[] wt, long cap) {
        int n = val.length;
        Item[] items = new Item[n];
        
        // 2. Populate the items array
        for (int i = 0; i < n; i++) {
            items[i] = new Item(val[i], wt[i]);
        }
        
        // 3. Sort the items by their ratio in DESCENDING order
        Arrays.sort(items, new Comparator<Item>() {
            @Override
            public int compare(Item a, Item b) {
                // Double.compare safely handles floating-point comparisons
                return Double.compare(b.ratio, a.ratio); 
            }
        });
        
        double totalValue = 0.0;
        long remainingCapacity = cap;
        
        // 4. Greedily fill the knapsack
        for (int i = 0; i < n; i++) {
            // Stop early if the bag is full
            if (remainingCapacity == 0) break; 
            
            if (items[i].wt <= remainingCapacity) {
                // If it fits completely, take the WHOLE item
                totalValue += items[i].val;
                remainingCapacity -= items[i].wt;
            } else {
                // If it doesn't fit, take a FRACTION of the item
                totalValue += items[i].ratio * remainingCapacity;
                remainingCapacity = 0; // The bag is now full
                break; // We are done
            }
        }
        
        return totalValue;
    }
}
