import java.util.*;

class Solution {
    // Move these to class level so the backtrack method can access them
    private List<List<String>> res;
    private int[] queens;
    private HashSet<Integer> cols;
    private HashSet<Integer> diags;
    private HashSet<Integer> antiDiags;
    private int size; // to store 'n' globally

    public List<List<String>> solveNQueens(int n) {
        res = new ArrayList<>();
        queens = new int[n];
        Arrays.fill(queens, -1);
        
       
        size = n;
        cols = new HashSet<>();
        diags = new HashSet<>();
        antiDiags = new HashSet<>();
        backtrack(0);
        return res;
    }

    // Java doesn't support nested functions; backtrack must be a separate method
    private void backtrack(int row) {
        if (row == size) {
            // When all queens are placed, build the board representation
            res.add(buildBoard());
            return;
        }
        
        for (int col = 0; col < size; col++) {
            if (cols.contains(col) || diags.contains(row - col) || antiDiags.contains(row + col)) {
                continue;
            }
            
            // Place the queen
            queens[row] = col;
            cols.add(col);
            diags.add(row - col);
            antiDiags.add(row + col);
            
            // Recurse to next row
            backtrack(row + 1);
            
            // Backtrack (Undo placement)
            queens[row] = -1;
            cols.remove(col);
            diags.remove(row - col);
            antiDiags.remove(row + col);
        }
    }

    // Helper method to convert the 'queens' array into the required list of strings
    private List<String> buildBoard() {
        List<String> board = new ArrayList<>();
        for (int i = 0; i < size; i++) {
            char[] rowChars = new char[size];
            Arrays.fill(rowChars, '.');
            rowChars[queens[i]] = 'Q';
            board.add(new String(rowChars));
        }
        return board;
    }
}
