import java.util.HashMap;

class Solution {
    public long subarrayXor(int arr[], int k) {
        long count = 0;
        int currentXor = 0;
        
        // HashMap to store the frequency of prefix XORs
        HashMap<Integer, Integer> xorMap = new HashMap<>();
        
        // Base case: A prefix XOR of 0 has occurred once (before looking at any element)
        xorMap.put(0, 1);
        
        for (int i = 0; i < arr.length; i++) {
            // Update the prefix XOR for the current element
            currentXor ^= arr[i];
            
            // If (currentXor ^ k) exists in the map, add its frequency to our count
            int target = currentXor ^ k;
            if (xorMap.containsKey(target)) {
                count += xorMap.get(target);
            }
            
            // Add/Update the current prefix XOR frequency in the map
            xorMap.put(currentXor, xorMap.getOrDefault(currentXor, 0) + 1);
        }
        
        return count;
    }
}
