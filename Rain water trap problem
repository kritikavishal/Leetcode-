class Solution {
    public int trap(int[] height) {
         int water_trap = 0;
         int right = height.length - 1;
         int left = 0;
         
         int left_max = 0;
         int right_max = 0;
         
         while (left < right) {
             // Left side is the bottleneck
            if (height[left] < height[right]) {
               // Update max OR calculate water for the CURRENT left block
               if (height[left] >= left_max) {
                    left_max = height[left];
               } else {
                    water_trap += left_max - height[left]; // Swapped '=' for '+=' and 'i' for 'left'
               }
               left++; // Moved this to the bottom of the block!
               
            } else { // Right side is the bottleneck
                // Update max OR calculate water for the CURRENT right block
                if (height[right] >= right_max) {
                    right_max = height[right];
                } else {
                    water_trap += right_max - height[right]; // Swapped '=' for '+=' and 'i' for 'right'
                }
                right--; // Added this so the loop doesn't run forever!
            }
         }
          
        return water_trap;
    }
}
