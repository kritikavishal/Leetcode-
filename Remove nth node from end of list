class Solution {
    public ListNode removeNthFromEnd(ListNode head, int n) {
        ListNode dummy = new ListNode(0);
        dummy.next = head;

        ListNode fast = dummy;
        ListNode slow = dummy;
        
        // FIX 1: Only move 'fast' to establish the gap of 'n' nodes.
        // We run the loop from 0 to n (n+1 times) so slow lands 1 step BEFORE the target.
        for (int i = 0; i <= n; i++) {
            fast = fast.next;
        }
        
        // Now move both pointers together until fast hits the end
        while (fast != null) {
            fast = fast.next;
            slow = slow.next;
        }
        
        // slow is now perfectly positioned right before the node to remove
        slow.next = slow.next.next;

        return dummy.next;
    } 
}
