# Definition for a binary tree node.
class TreeNode(object):
    def __init__(self, val=0, left=None, right=None):
        self.val = val
        self.left = left
        self.right = right

class Solution:
    def searchBST(self, root, val):
        cur = root
        while cur is not None:
            if cur.val == val:
                return cur
            elif cur.val < val:
                # If current is less than target, target is LARGER. Go right.
                cur = cur.right 
            else:
                # If current is greater than target, target is SMALLER. Go left.
                cur = cur.left  
        return None
