class Solution:
    def stockSpan(self, arr, n):
        # 1. Variables and setup MUST go inside the function
        res = []
        res.append(1)
        
        for i in range(1, n):
            cur = arr[i] # 2. Define cur for today
            count = 1    # 3. Reset count to 1 for today
            
            j = i - 1
            
            while j >= 0 and arr[j] <= cur:
                count += 1
                j -= 1
                
            res.append(count)
            
        # 4. Return lines up with the for loop
        return res
