from collections import deque, defaultdict

class Solution:
    def verticalOrder(self, root):
        # 1. Base case
        if not root:
            return []
        
        # 2. Setup hash map and BFS queue
        col_map = defaultdict(list)
        queue = deque([(root, 0)]) # Stores tuples of (node, column)
        
        # Track the leftmost and rightmost columns to avoid sorting keys later
        min_col = 0
        max_col = 0
        
        # 3. BFS Traversal
        while queue:
            node, col = queue.popleft()
            
            if node:
                # Add the node's data to its corresponding column list
                col_map[col].append(node.data)
                
                # Update the boundaries
                min_col = min(min_col, col)
                max_col = max(max_col, col)
                
                # Push left child (column - 1)
                if node.left:
                    queue.append((node.left, col - 1))
                
                # Push right child (column + 1)
                if node.right:
                    queue.append((node.right, col + 1))
        
        # 4. Build the final result
        result = []
        for i in range(min_col, max_col + 1):
            result.append(col_map[i])
            
        return result
