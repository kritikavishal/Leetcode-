class Solution:
    def wordBreak(self, s: str, wordDict: list[str]) -> bool:
        # Convert wordDict to a set for O(1) lookups
        word_set = set(wordDict)
        
        # dp[i] represents whether s[:i] can be segmented into dictionary words
        dp = [False] * (len(s) + 1)
        
        # Base case: an empty string can always be segmented
        dp[0] = True 
        
        # Iterate through the string to build our DP array
        for i in range(1, len(s) + 1):
            for j in range(i):
                # If the string up to 'j' is valid, AND the substring from 'j' to 'i' is in the dictionary
                if dp[j] and s[j:i] in word_set:
                    dp[i] = True
                    break # We found a valid segmentation ending at i, no need to check further j's
                    
        # The last element tells us if the entire string can be segmented
        return dp[len(s)]
