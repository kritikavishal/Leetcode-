class Solution:
    def nextLargerElement(self, arr):
        n = len(arr)         # 1. Define n!
        res = [-1] * n       # 2. Pre-fill the result array with -1s
        
        # 3. Loop through every single element
        for i in range(n):
            right = i + 1
            
            # 4. Search forward to find the next greater element
            while right < n:
                if arr[right] > arr[i]:
                    res[i] = arr[right] # Found it! Update the answer.
                    break               # Stop searching for this 'i'
                
                # If it wasn't bigger, move the scanner forward
                right += 1
                
        # 5. Just return the list!
        return res
