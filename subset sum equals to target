class Solution {
    public boolean isSubsetSum(int[] arr, int target) {
        int n = arr.length;
        
        // STEP 1: Initialize a normal DP table
        // Rows represent elements (0 to n), Columns represent target sums (0 to target)
        boolean[][] dp = new boolean[n + 1][target + 1];

        // Base Case 1: Target sum of 0 is always possible (empty subset)
        for (int i = 0; i <= n; i++) {
            dp[i][0] = true;
        }

        // Base Case 2: With 0 elements, no positive sum is possible
        for (int j = 1; j <= target; j++) {
            dp[0][j] = false; 
        }

        // STEP 2: Fill all possible combinations for the target
        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= target; j++) {
                
                // If the current element is greater than the current sum 'j', we must exclude it
                if (arr[i - 1] > j) {
                    dp[i][j] = dp[i - 1][j];
                } 
                // Otherwise, we see if it's possible by either Excluding OR Including it
                else {
                    dp[i][j] = dp[i - 1][j] || dp[i - 1][j - arr[i - 1]];
                }
            }
        }

        // STEPS 3 & 4: Look if it can do it or not, and return true or false
        return dp[n][target];
    }
}


